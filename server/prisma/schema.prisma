generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("CLIENT") // ADMIN or CLIENT
  createdAt    DateTime @default(now())

  keyPairs            KeyPair[]
  certificateRequests CertificateRequest[]
  certificates        Certificate[]
  revocationRequests  RevocationRequest[]
  uploadedCerts       UploadedCertificate[]
  auditLogs           AuditLog[]
}

model CaConfig {
  id            String @id @default(cuid())
  algorithm     String @default("RSA")
  hashAlgorithm String @default("SHA-256")
  keyLength     Int    @default(2048)
  validityDays  Int    @default(365)
  rootKeyPem    String?
  rootCertPem   String?
  updatedAt     DateTime @updatedAt
}

model KeyPair {
  id            String   @id @default(cuid())
  userId        String
  label         String
  publicKeyPem  String
  privateKeyPem String
  keyLength     Int      @default(2048)
  createdAt     DateTime @default(now())

  user                User                 @relation(fields: [userId], references: [id])
  certificateRequests CertificateRequest[]
}

model CertificateRequest {
  id           String   @id @default(cuid())
  userId       String
  keyPairId    String
  csrPem       String
  domain       String
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  keyPair     KeyPair      @relation(fields: [keyPairId], references: [id])
  certificate Certificate?
}

model Certificate {
  id           String    @id @default(cuid())
  requestId    String?   @unique
  userId       String
  certPem      String
  serialNumber String    @unique
  subjectDN    String
  issuerDN     String
  notBefore    DateTime
  notAfter     DateTime
  status       String    @default("ACTIVE") // ACTIVE, REVOKED
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  request            CertificateRequest? @relation(fields: [requestId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  revocationRequests RevocationRequest[]
}

model RevocationRequest {
  id            String   @id @default(cuid())
  certificateId String
  userId        String
  reason        String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  certificate Certificate @relation(fields: [certificateId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
}

model CRL {
  id         String   @id @default(cuid())
  crlPem     String
  issuedAt   DateTime @default(now())
  nextUpdate DateTime
}

model UploadedCertificate {
  id        String   @id @default(cuid())
  userId    String
  certPem   String
  label     String
  subjectDN String
  issuerDN  String
  notBefore DateTime
  notAfter  DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  username  String
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
